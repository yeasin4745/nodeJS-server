{
  "name": "nodejs-server",
  "version": "2.0.0",
  "description": "A modern Node.js server with modular architecture",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "echo 'No build step required for this project'",
    "logs": "tail -f logs/server.log"
  },
  "keywords": [
    "nodejs",
    "server",
    "express",
    "web-server",
    "modular",
    "rest-api"
  ],
  "author": "Md Yeasin Ali",
  "license": "ISC",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yeasin4745/nodeJS-server.git"
  },
  "bugs": {
    "url": "https://github.com/yeasin4745/nodeJS-server/issues"
  },
  "homepage": "https://github.com/yeasin4745/nodeJS-server#readme",
  "dependencies": {},
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.45.0"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 12
    },
    "rules": {
      "indent": [
        "error",
        4
      ],
      "linebreak-style": [
        "error",
        "unix"
      ],
      "quotes": [
        "error",
        "single"
      ],
      "semi": [
        "error",
        "always"
      ]
    }
  }
}